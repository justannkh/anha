# ═══════════════════════════════════════════════════════
#  Ankha Bot — Настройки окружения
#  Скопируй этот файл как .env и заполни значения:
#  cp .env.example .env
#
#  ВАЖНО: тут только секреты, ID и ссылки.
#  Игровые настройки (цены магазина, кулдауны, награды,
#  лимиты казино, тексты персон ИИ) теперь в config.py —
#  правь их прямо там, без .env.
# ═══════════════════════════════════════════════════════

# ─── Секреты ───
BOT_TOKEN=
GROQ_API_KEY=

# ─── ID ───
OWNER_ID=
ALLOWED_GROUP_ID=

# ID друга/коллеги (необязательно, 0 = отключено)
FRIEND_ID=

# ID лучшей подружки Анхи (Тапка). По умолчанию уже задан в config.py
BESTIE_ID=1824278671

# Telegram-канал для постинга YouTube-видео (числовой ID)
PUBLISH_CHANNEL_ID=0

# ID YouTube-канала (начинается с UC...)
YOUTUBE_CHANNEL_ID=

# ─── Ссылки (команда .ссылки) ───
LINK_TG_CHANNEL=https://t.me/UnkTale
LINK_BOOSTI=https://boosty.to/ankh
LINK_ARCHIVE=https://t.me/+-3MrQ-yJBlVkMmNi
LINK_YOUTUBE_CH=http://www.youtube.com/@JustAnkh

# Ссылка для товара «Подписка Boosty» в магазине
SHOP_BOOSTI_URL=https://boosty.to/ankh
